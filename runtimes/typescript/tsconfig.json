{
  "compilerOptions": {
    "target": "es2015",
    "lib": ["es5", "es6", "dom"],
    "types": ["node"],
    "module": "node16",
    "moduleResolution": "node16",
    "rootDir": "./src",
    "outDir": "./bin",
    "strictNullChecks": true,
    "sourceMap": true
  },
  "exclude": [
    "bin",
    "node_modules",
    "tests",
    "vitest.config.ts"
  ]
}
