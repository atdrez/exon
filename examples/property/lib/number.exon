***
Enforce number type checking
***

using fn.*

property {
    _value: 0

    get: get {
        target: @root
        property: "_value"
    }

    set: set {
        target: @root
        property: "_value"
        value: sequence {
            assert {
                number.is { parameter { "value" } }
                message: "Invalid type: must be number"
            }
            parameter { "value" }
        }
    }
}