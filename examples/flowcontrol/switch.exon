// Usage example:
// ENV=production ./ts-run.sh examples/flowcontrol/switch.exon

using fn.*

{
    name: "Switch Sample"

    info: switch {
        value: process.env { "ENV" }

        production:
            "This is a production enviroment"
        development:
            "This is a development enviroment"
        __default:
            "No environment found"
    }
}