using fn.*

fn.wrapper {
    content: sequence@seq {
        name: get { target: @root.__content__ index: 0 }
        value: get { target: @root.__content__ index: 1 }

        _check: assert {
            and {
                string.is { @seq.name }
                string.is { @seq.value }
            }
            message: "Invalid value"
        }

        {
            _d_input_string: true
            name: @seq.name
            value: @seq.value
        }
    }
}