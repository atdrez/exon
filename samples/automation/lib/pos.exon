using fn.*

fn.wrapper {
    content: sequence@seq {
        x: get { target: @root.__content__ index: 0 }
        y: get { target: @root.__content__ index: 1 }

        assert {
            and {
                number.is { @seq.x }
                number.is { @seq.y }
            }
            message: "Invalid position"
        }

        [@seq.x, @seq.y]
    }
}