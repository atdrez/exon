***
Enforce string type checking
***

using fn.*

property {
    _value: ""

    get: get {
        target: @root
        property: "_value"
    }

    set: set {
        target: @root
        property: "_value"
        value: sequence {
            assert {
                string.is { parameter { "value" } }
                message: "Invalid type: must be string"
            }
            parameter { "value" }
        }
    }
}