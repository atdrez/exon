{
  "compilerOptions": {
    "target": "es2015",
    "lib": ["es5", "es6", "dom"],
    "types": ["node"],
    "module": "commonjs",
    "moduleResolution": "bundler",
    "rootDir": "./src",
    "outDir": "./bin",
    "strictNullChecks": true,
    "noImplicitAny": false,
    "sourceMap": true
  },
  "exclude": [
    "bin",
    "node_modules"
  ]
}
