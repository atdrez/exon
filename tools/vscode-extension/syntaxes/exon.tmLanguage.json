{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Exon",
    "scopeName": "source.exon",
    "fileTypes": ["exon"],
    "patterns": [
        { "include": "#comment-line" },
        { "include": "#comment-block" },
        { "include": "#using-directive" },
        { "include": "#string-triple" },
        { "include": "#string-single" },
        { "include": "#number" },
        { "include": "#constants" },
        { "include": "#meta-key" },
        { "include": "#binding-declaration" },
        { "include": "#fn-type" },
        { "include": "#type-name" },
        { "include": "#binding-ref" },
        { "include": "#merge-operator" },
        { "include": "#property-key" },
        { "include": "#punctuation" }
    ],
    "repository": {
        "using-directive": {
            "match": "^\\s*(using)\\s+((?:\\.{1,3})?[a-zA-Z_][a-zA-Z0-9_.]*(?:\\.\\*)?)",
            "captures": {
                "1": { "name": "keyword.control.import.exon" },
                "2": { "name": "entity.name.namespace.exon" }
            }
        },
        "comment-line": {
            "name": "comment.line.double-slash.exon",
            "match": "//.*$"
        },
        "comment-block": {
            "name": "comment.block.exon",
            "begin": "\\*\\*\\*",
            "end": "\\*\\*\\*",
            "beginCaptures": {
                "0": { "name": "punctuation.definition.comment.begin.exon" }
            },
            "endCaptures": {
                "0": { "name": "punctuation.definition.comment.end.exon" }
            }
        },
        "string-triple": {
            "name": "string.quoted.triple.exon",
            "begin": "\"\"\"",
            "end": "\"\"\"",
            "beginCaptures": {
                "0": { "name": "punctuation.definition.string.begin.exon" }
            },
            "endCaptures": {
                "0": { "name": "punctuation.definition.string.end.exon" }
            }
        },
        "string-single": {
            "name": "string.quoted.double.exon",
            "begin": "\"",
            "end": "\"",
            "beginCaptures": {
                "0": { "name": "punctuation.definition.string.begin.exon" }
            },
            "endCaptures": {
                "0": { "name": "punctuation.definition.string.end.exon" }
            },
            "patterns": [
                {
                    "name": "constant.character.escape.exon",
                    "match": "\\\\."
                }
            ]
        },
        "number": {
            "name": "constant.numeric.exon",
            "match": "-?\\b[0-9]+(?:\\.[0-9]+)?\\b"
        },
        "constants": {
            "name": "constant.language.exon",
            "match": "\\b(true|false|null)\\b"
        },
        "meta-key": {
            "name": "variable.language.meta.exon",
            "match": "\\b(__[a-zA-Z_][a-zA-Z0-9_]*__)\\s*(?=:)"
        },
        "binding-declaration": {
            "match": "\\b([a-zA-Z_][a-zA-Z0-9_.]*)(@[a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*\\{)",
            "captures": {
                "1": { "name": "entity.name.type.exon" },
                "2": { "name": "entity.name.tag.exon" }
            }
        },
        "fn-type": {
            "match": "\\b(fn(?:\\.[a-zA-Z_][a-zA-Z0-9_]*)*)(?=\\s*\\{)",
            "captures": {
                "1": { "name": "support.function.exon" }
            }
        },
        "type-name": {
            "match": "\\b([a-zA-Z_][a-zA-Z0-9_.]*)(?=\\s*\\{)",
            "captures": {
                "1": { "name": "entity.name.type.exon" }
            }
        },
        "binding-ref": {
            "name": "variable.other.readwrite.exon",
            "match": "@[a-zA-Z_][a-zA-Z0-9_]*(?:\\.[a-zA-Z_][a-zA-Z0-9_]*)*"
        },
        "merge-operator": {
            "name": "keyword.operator.merge.exon",
            "match": "\\b_\\b(?=\\s*\\{)"
        },
        "property-key": {
            "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=:(?!:))",
            "captures": {
                "1": { "name": "variable.other.property.exon" }
            }
        },
        "punctuation": {
            "patterns": [
                { "name": "punctuation.definition.block.begin.exon", "match": "\\{" },
                { "name": "punctuation.definition.block.end.exon",   "match": "\\}" },
                { "name": "punctuation.definition.array.begin.exon", "match": "\\[" },
                { "name": "punctuation.definition.array.end.exon",   "match": "\\]" },
                { "name": "punctuation.separator.key-value.exon",    "match": ":" },
                { "name": "punctuation.separator.comma.exon",        "match": "," },
                { "name": "punctuation.terminator.exon",             "match": ";" }
            ]
        }
    }
}
