fn.wrapper {
    __content__: [ 0, 0 ]

    content: fn.sequence {
        fn.get@left { target: @root; property: "__content__"; index: 0 }
        fn.get@right { target: @root; property: "__content__"; index: 1 }

        fn.cond {
            fn.le { @left @right } @left
            @right
        }
    }
}