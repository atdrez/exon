fn.wrapper {
    __content__: []

    format: "js"
    extension: "exon"

    content: fn.sequence@seq {
        name: fn.get{ target: @root property: "__content__" index: 0 }

        fn.string.join {
            "<pre><code class=\"language-exon\">"
            fn.file.load{ path: fn.string.join { "../../../examples/" @seq.name "." @root.extension } }
            "</code></pre>"
        }
    }
}